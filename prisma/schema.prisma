generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AccountStatus {
  pending
  active
  suspended
  rejected
  deactivated
}

enum VerificationStatus {
  unverified
  pending
  verified
  rejected
  suspended
}

enum DeliveryRequestStatus {
  draft
  payment_initiated
  payment_confirmed
  created
  marketplace_open
  offers_received
  provider_assigned
  pickup_verified
  in_transit
  delivered
  completed
  cancelled
  disputed
  expired
}

enum PaymentStatus {
  unpaid
  initiated
  pending
  confirmed
  failed
  cancelled
  refunded
}

enum FulfillmentMode {
  open_marketplace
  recommended_provider
  search_provider
  agency_dispatch
}

enum OfferStatus {
  submitted
  accepted
  rejected
  expired
  withdrawn
}

enum AvailabilityStatus {
  available
  unavailable
  busy
  offline
}

enum ProviderType {
  independent_rider
  courier_company
  logistics_company
}

enum VerificationCodeType {
  pickup
  delivery
  phone_verification
  payment_confirmation
}

enum PaymentProviderStatus {
  initiated
  pending
  confirmed
  failed
  cancelled
  refunded
}

enum EscrowStatus {
  held
  released
  refunded
  disputed
  partially_released
}

enum WalletStatus {
  active
  frozen
  closed
}

enum WalletTransactionType {
  credit
  debit
  payout
  refund
  commission
  adjustment
}

enum DispatchAssignmentStatus {
  suggested
  assigned
  accepted
  rejected
  in_progress
  completed
  cancelled
}

enum IdentityVerificationType {
  phone
  national_id
  profile
  business_registration
  agency_document
  rider_identity
}

enum ReviewStatus {
  pending
  approved
  rejected
  expired
}

enum NotificationChannel {
  dashboard
  whatsapp
  email
  sms
}

enum NotificationStatus {
  pending
  sent
  delivered
  failed
  cancelled
}

enum ProofType {
  pickup_photo
  package_photo
  delivery_photo
  delivery_confirmation
  signature
  other
}

enum CommissionType {
  percentage
  fixed
}

model User {
  id                    String           @id @default(uuid()) @db.Uuid
  fullName              String           @map("full_name") @db.VarChar(160)
  phone                 String           @unique @db.VarChar(32)
  email                 String?          @unique @db.VarChar(255)
  passwordHash          String?          @map("password_hash")
  avatarFileId          String?          @map("avatar_file_id") @db.Uuid
  accountStatus         AccountStatus    @default(pending) @map("account_status")
  phoneVerifiedAt       DateTime?        @map("phone_verified_at") @db.Timestamptz
  emailVerifiedAt       DateTime?        @map("email_verified_at") @db.Timestamptz
  lastLoginAt           DateTime?        @map("last_login_at") @db.Timestamptz
  createdAt             DateTime         @default(now()) @map("created_at") @db.Timestamptz
  updatedAt             DateTime         @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt             DateTime?        @map("deleted_at") @db.Timestamptz
  createdBy             String?          @map("created_by") @db.Uuid
  updatedBy             String?          @map("updated_by") @db.Uuid
  roles                 UserRole[]
  providerProfile       ProviderProfile?
  customerContacts      CustomerContact[]
  agencyMembers         AgencyMember[]
  createdAgencies       Agency[]         @relation("AgencyCreatedBy")
  updatedAgencies       Agency[]         @relation("AgencyUpdatedBy")
  trackingEvents        TrackingEvent[]  @relation("TrackingResponsibleUser")
  receivedNotifications Notification[]   @relation("NotificationRecipientUser")
  auditLogs             AuditLog[]

  @@index([accountStatus], map: "idx_users_account_status")
  @@index([deletedAt], map: "idx_users_deleted_at")
  @@map("users")
}

model Role {
  id          String     @id @default(uuid()) @db.Uuid
  code        String     @unique @db.VarChar(64)
  name        String     @db.VarChar(120)
  description String?
  createdAt   DateTime   @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime   @updatedAt @map("updated_at") @db.Timestamptz
  userRoles   UserRole[]

  @@map("roles")
}

model UserRole {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  roleId    String    @map("role_id") @db.Uuid
  agencyId  String?   @map("agency_id") @db.Uuid
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz
  user      User      @relation(fields: [userId], references: [id])
  role      Role      @relation(fields: [roleId], references: [id])
  agency    Agency?   @relation(fields: [agencyId], references: [id])

  @@unique([userId, roleId, agencyId])
  @@index([userId], map: "idx_user_roles_user_id")
  @@index([roleId], map: "idx_user_roles_role_id")
  @@index([agencyId], map: "idx_user_roles_agency_id")
  @@map("user_roles")
}

model CustomerContact {
  id                String            @id @default(uuid()) @db.Uuid
  // Null for anonymous contacts; set when an authenticated user creates the contact.
  userId            String?           @map("user_id") @db.Uuid
  fullName          String            @map("full_name") @db.VarChar(160)
  phone             String?           @db.VarChar(32)
  whatsappNumber    String            @map("whatsapp_number") @db.VarChar(32)
  paymentNumber     String?           @map("payment_number") @db.VarChar(32)
  email             String?           @db.VarChar(255)
  preferredLanguage String?           @default("en") @map("preferred_language") @db.VarChar(16)
  createdAt         DateTime          @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime          @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt         DateTime?         @map("deleted_at") @db.Timestamptz
  user              User?             @relation(fields: [userId], references: [id])
  requests          DeliveryRequest[]
  payments          Payment[]
  notifications     Notification[]
  reviews           ReviewRating[]
  auditLogs         AuditLog[]

  @@index([userId], map: "idx_customer_contacts_user_id")
  @@index([whatsappNumber], map: "idx_customer_contacts_whatsapp")
  @@index([email], map: "idx_customer_contacts_email")
  @@map("customer_contacts")
}

model Agency {
  id                 String               @id @default(uuid()) @db.Uuid
  name               String               @db.VarChar(180)
  legalName          String?              @map("legal_name") @db.VarChar(220)
  slug               String?              @unique @db.VarChar(120)
  description        String?
  phone              String?              @db.VarChar(32)
  email              String?              @db.VarChar(255)
  logoFileId         String?              @map("logo_file_id") @db.Uuid
  address            String?
  city               String?              @db.VarChar(120)
  country            String?              @default("Cameroon") @db.VarChar(120)
  verificationStatus VerificationStatus   @default(unverified) @map("verification_status")
  subscriptionStatus String               @default("inactive") @map("subscription_status") @db.VarChar(32)
  isFeatured         Boolean              @default(false) @map("is_featured")
  createdAt          DateTime             @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime             @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt          DateTime?            @map("deleted_at") @db.Timestamptz
  createdBy          String?              @map("created_by") @db.Uuid
  updatedBy          String?              @map("updated_by") @db.Uuid
  creator            User?                @relation("AgencyCreatedBy", fields: [createdBy], references: [id])
  updater            User?                @relation("AgencyUpdatedBy", fields: [updatedBy], references: [id])
  members            AgencyMember[]
  userRoles          UserRole[]
  providerProfiles   ProviderProfile[]
  pricingRules       PricingRule[]
  riders             Rider[]
  dispatches         DispatchAssignment[]
  subscriptions      AgencySubscription[]
  notifications      Notification[]

  @@index([city], map: "idx_agencies_city")
  @@index([verificationStatus], map: "idx_agencies_verification_status")
  @@index([isFeatured], map: "idx_agencies_featured")
  @@map("agencies")
}

model AgencyMember {
  id         String    @id @default(uuid()) @db.Uuid
  agencyId   String    @map("agency_id") @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  memberRole String    @map("member_role") @db.VarChar(64)
  status     String    @default("active") @db.VarChar(32)
  joinedAt   DateTime  @default(now()) @map("joined_at") @db.Timestamptz
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt  DateTime? @map("deleted_at") @db.Timestamptz
  agency     Agency    @relation(fields: [agencyId], references: [id])
  user       User      @relation(fields: [userId], references: [id])

  @@unique([agencyId, userId])
  @@index([agencyId], map: "idx_agency_members_agency_id")
  @@index([userId], map: "idx_agency_members_user_id")
  @@map("agency_members")
}

model ProviderProfile {
  id                 String             @id @default(uuid()) @db.Uuid
  userId             String?            @unique @map("user_id") @db.Uuid
  agencyId           String?            @map("agency_id") @db.Uuid
  providerType       ProviderType       @map("provider_type")
  displayName        String             @map("display_name") @db.VarChar(180)
  description        String?
  serviceCoverage    String?            @map("service_coverage")
  baseCity           String?            @map("base_city") @db.VarChar(120)
  baseCountry        String?            @default("Cameroon") @map("base_country") @db.VarChar(120)
  phoneNumber        String?            @map("phone_number") @db.VarChar(32)
  businessAddress    String?            @map("business_address")
  businessLat        Decimal?           @map("business_lat") @db.Decimal(10, 7)
  businessLng        Decimal?           @map("business_lng") @db.Decimal(10, 7)
  priceInTown        Decimal?           @map("price_in_town") @db.Decimal(12, 2)
  priceInRegion      Decimal?           @map("price_in_region") @db.Decimal(12, 2)
  ratingAverage      Decimal            @default(0) @map("rating_average") @db.Decimal(3, 2)
  ratingCount        Int                @default(0) @map("rating_count")
  verificationStatus VerificationStatus @default(unverified) @map("verification_status")
  availabilityStatus AvailabilityStatus @default(available) @map("availability_status")
  isFeatured         Boolean            @default(false) @map("is_featured")
  createdAt          DateTime           @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime           @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt          DateTime?          @map("deleted_at") @db.Timestamptz
  createdBy          String?            @map("created_by") @db.Uuid
  updatedBy          String?            @map("updated_by") @db.Uuid
  user               User?              @relation(fields: [userId], references: [id])
  agency             Agency?            @relation(fields: [agencyId], references: [id])
  pricingRules       PricingRule[]
  selectedRequests   DeliveryRequest[]  @relation("SelectedProvider")
  offers             MarketplaceOffer[]
  reviews            ReviewRating[]
  milestoneEvents    TrackingEvent[]    @relation("TrackingResponsibleProvider")
  uploadedFiles      UploadedFile[]     @relation("ProviderUploadedFiles")
  branches           ProviderBranch[]
  riderRoutes        RiderRoute[]

  @@index([providerType], map: "idx_provider_profiles_type")
  @@index([baseCity], map: "idx_provider_profiles_city")
  @@index([ratingAverage], map: "idx_provider_profiles_rating")
  @@index([verificationStatus], map: "idx_provider_profiles_verification")
  @@index([isFeatured], map: "idx_provider_profiles_featured")
  @@map("provider_profiles")
}

model PricingRule {
  id                String           @id @default(uuid()) @db.Uuid
  providerProfileId String?          @map("provider_profile_id") @db.Uuid
  agencyId          String?          @map("agency_id") @db.Uuid
  deliveryType      String?          @map("delivery_type") @db.VarChar(64)
  baseFee           Decimal          @default(0) @map("base_fee") @db.Decimal(12, 2)
  pricePerKm        Decimal          @default(0) @map("price_per_km") @db.Decimal(12, 2)
  pricePerKg        Decimal          @default(0) @map("price_per_kg") @db.Decimal(12, 2)
  fragileItemFee    Decimal          @default(0) @map("fragile_item_fee") @db.Decimal(12, 2)
  minPrice          Decimal?         @map("min_price") @db.Decimal(12, 2)
  maxPrice          Decimal?         @map("max_price") @db.Decimal(12, 2)
  currency          String           @default("XAF") @db.VarChar(8)
  isActive          Boolean          @default(true) @map("is_active")
  createdAt         DateTime         @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime         @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt         DateTime?        @map("deleted_at") @db.Timestamptz
  providerProfile   ProviderProfile? @relation(fields: [providerProfileId], references: [id])
  agency            Agency?          @relation(fields: [agencyId], references: [id])

  @@index([providerProfileId], map: "idx_pricing_rules_provider")
  @@index([agencyId], map: "idx_pricing_rules_agency")
  @@index([deliveryType], map: "idx_pricing_rules_delivery_type")
  @@index([isActive], map: "idx_pricing_rules_active")
  @@map("pricing_rules")
}

model DeliveryRequest {
  id                        String                @id @default(uuid()) @db.Uuid
  publicTrackingCode        String                @unique @map("public_tracking_code") @db.VarChar(40)
  customerContactId         String                @map("customer_contact_id") @db.Uuid
  requestStatus             DeliveryRequestStatus @default(draft) @map("request_status")
  paymentStatus             PaymentStatus         @default(unpaid) @map("payment_status")
  fulfillmentMode           FulfillmentMode?      @map("fulfillment_mode")
  deliveryType              String                @map("delivery_type") @db.VarChar(64)
  expectedDeliveryDate      DateTime?             @map("expected_delivery_date") @db.Date
  expectedDeliveryTime      DateTime?             @map("expected_delivery_time") @db.Time
  selectedProviderProfileId String?               @map("selected_provider_profile_id") @db.Uuid
  selectedAgencyId          String?               @map("selected_agency_id") @db.Uuid
  acceptedOfferId           String?               @unique @map("accepted_offer_id") @db.Uuid
  desiredRewardAmount       Decimal?              @map("desired_reward_amount") @db.Decimal(12, 2)
  deliveryCost              Decimal?              @map("delivery_cost") @db.Decimal(12, 2)
  platformFee               Decimal               @default(0) @map("platform_fee") @db.Decimal(12, 2)
  totalAmount               Decimal?              @map("total_amount") @db.Decimal(12, 2)
  currency                  String                @default("XAF") @db.VarChar(8)
  paymentConfirmedAt        DateTime?             @map("payment_confirmed_at") @db.Timestamptz
  providerAssignedAt        DateTime?             @map("provider_assigned_at") @db.Timestamptz
  completedAt               DateTime?             @map("completed_at") @db.Timestamptz
  cancelledAt               DateTime?             @map("cancelled_at") @db.Timestamptz
  createdAt                 DateTime              @default(now()) @map("created_at") @db.Timestamptz
  updatedAt                 DateTime              @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt                 DateTime?             @map("deleted_at") @db.Timestamptz
  createdBy                 String?               @map("created_by") @db.Uuid
  updatedBy                 String?               @map("updated_by") @db.Uuid
  customerContact           CustomerContact       @relation(fields: [customerContactId], references: [id])
  selectedProvider          ProviderProfile?      @relation("SelectedProvider", fields: [selectedProviderProfileId], references: [id])
  route                     RequestRoute?
  items                     RequestItem[]
  providerSelection         ProviderSelection?
  offers                    MarketplaceOffer[]    @relation("RequestOffers")
  acceptedOffer             MarketplaceOffer?     @relation("AcceptedOffer", fields: [acceptedOfferId], references: [id])
  trackingEvents            TrackingEvent[]
  verificationCodes         VerificationCode[]
  proofRecords              ProofRecord[]
  payments                  Payment[]
  dispatchAssignments       DispatchAssignment[]
  escrowTransactions        EscrowTransaction[]
  reviews                   ReviewRating[]

  @@index([customerContactId], map: "idx_delivery_requests_customer")
  @@index([requestStatus], map: "idx_delivery_requests_status")
  @@index([paymentStatus], map: "idx_delivery_requests_payment_status")
  @@index([fulfillmentMode], map: "idx_delivery_requests_fulfillment_mode")
  @@index([deliveryType], map: "idx_delivery_requests_delivery_type")
  @@index([expectedDeliveryDate], map: "idx_delivery_requests_expected_date")
  @@index([selectedProviderProfileId], map: "idx_delivery_requests_selected_provider")
  @@index([selectedAgencyId], map: "idx_delivery_requests_selected_agency")
  @@index([createdAt], map: "idx_delivery_requests_created_at")
  @@map("delivery_requests")
}

model Region {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @unique @db.VarChar(120)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz
  towns     Town[]

  @@map("regions")
}

model Town {
  id        String    @id @default(uuid()) @db.Uuid
  regionId  String    @map("region_id") @db.Uuid
  name      String    @db.VarChar(120)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  region    Region    @relation(fields: [regionId], references: [id])
  quarters  Quarter[]

  @@unique([regionId, name])
  @@index([regionId], map: "idx_towns_region_id")
  @@map("towns")
}

model Quarter {
  id                String         @id @default(uuid()) @db.Uuid
  townId            String         @map("town_id") @db.Uuid
  name              String         @db.VarChar(160)
  createdAt         DateTime       @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime       @updatedAt @map("updated_at") @db.Timestamptz
  town                    Town             @relation(fields: [townId], references: [id])
  pickupRoutes            RequestRoute[]   @relation("PickupQuarter")
  destinationRoutes       RequestRoute[]   @relation("DestinationQuarter")
  providerBranches        ProviderBranch[]
  riderRoutesAsOrigin     RiderRoute[]     @relation("RiderRouteOrigin")
  riderRoutesAsDestination RiderRoute[]   @relation("RiderRouteDestination")

  @@unique([townId, name])
  @@index([townId], map: "idx_quarters_town_id")
  @@map("quarters")
}

model RequestRoute {
  id                       String          @id @default(uuid()) @db.Uuid
  deliveryRequestId        String          @unique @map("delivery_request_id") @db.Uuid
  pickupQuarterId          String          @map("pickup_quarter_id") @db.Uuid
  pickupLandmark           String          @map("pickup_landmark")
  pickupCountry            String?         @default("Cameroon") @map("pickup_country") @db.VarChar(120)
  pickupLat                Decimal?        @map("pickup_lat") @db.Decimal(10, 7)
  pickupLng                Decimal?        @map("pickup_lng") @db.Decimal(10, 7)
  destinationQuarterId     String          @map("destination_quarter_id") @db.Uuid
  destinationLandmark      String          @map("destination_landmark")
  destinationCountry       String?         @default("Cameroon") @map("destination_country") @db.VarChar(120)
  destinationLat           Decimal?        @map("destination_lat") @db.Decimal(10, 7)
  destinationLng           Decimal?        @map("destination_lng") @db.Decimal(10, 7)
  estimatedDistanceKm      Decimal?        @map("estimated_distance_km") @db.Decimal(10, 2)
  estimatedDurationMinutes Int?            @map("estimated_duration_minutes")
  suggestedRouteSummary    String?         @map("suggested_route_summary")
  mapProvider              String?         @map("map_provider") @db.VarChar(64)
  createdAt                DateTime        @default(now()) @map("created_at") @db.Timestamptz
  updatedAt                DateTime        @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt                DateTime?       @map("deleted_at") @db.Timestamptz
  deliveryRequest          DeliveryRequest @relation(fields: [deliveryRequestId], references: [id])
  pickupQuarter            Quarter         @relation("PickupQuarter", fields: [pickupQuarterId], references: [id])
  destinationQuarter       Quarter         @relation("DestinationQuarter", fields: [destinationQuarterId], references: [id])

  @@index([pickupQuarterId], map: "idx_request_routes_pickup_quarter")
  @@index([destinationQuarterId], map: "idx_request_routes_destination_quarter")
  @@map("request_routes")
}

model RequestItem {
  id                  String          @id @default(uuid()) @db.Uuid
  deliveryRequestId   String          @map("delivery_request_id") @db.Uuid
  itemName            String          @map("item_name") @db.VarChar(180)
  itemDescription     String?         @map("item_description")
  category            String?         @db.VarChar(100)
  weightKg            Decimal?        @map("weight_kg") @db.Decimal(10, 2)
  sizeLabel           String?         @map("size_label") @db.VarChar(64)
  quantity            Int             @default(1)
  photoFileId         String?         @map("photo_file_id") @db.Uuid
  isFragile           Boolean         @default(false) @map("is_fragile")
  specialInstructions String?         @map("special_instructions")
  createdAt           DateTime        @default(now()) @map("created_at") @db.Timestamptz
  updatedAt           DateTime        @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt           DateTime?       @map("deleted_at") @db.Timestamptz
  deliveryRequest     DeliveryRequest @relation(fields: [deliveryRequestId], references: [id])

  @@index([deliveryRequestId], map: "idx_request_items_request")
  @@index([category], map: "idx_request_items_category")
  @@index([isFragile], map: "idx_request_items_fragile")
  @@map("request_items")
}

model ProviderSelection {
  id                        String          @id @default(uuid()) @db.Uuid
  deliveryRequestId         String          @unique @map("delivery_request_id") @db.Uuid
  selectionMode             FulfillmentMode @map("selection_mode")
  selectedProviderProfileId String?         @map("selected_provider_profile_id") @db.Uuid
  selectedAgencyId          String?         @map("selected_agency_id") @db.Uuid
  estimatedMinPrice         Decimal?        @map("estimated_min_price") @db.Decimal(12, 2)
  estimatedMaxPrice         Decimal?        @map("estimated_max_price") @db.Decimal(12, 2)
  finalPrice                Decimal?        @map("final_price") @db.Decimal(12, 2)
  recommendationScore       Decimal?        @map("recommendation_score") @db.Decimal(8, 4)
  selectionMetadata         Json?           @map("selection_metadata")
  createdAt                 DateTime        @default(now()) @map("created_at") @db.Timestamptz
  updatedAt                 DateTime        @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt                 DateTime?       @map("deleted_at") @db.Timestamptz
  deliveryRequest           DeliveryRequest @relation(fields: [deliveryRequestId], references: [id])

  @@index([selectionMode], map: "idx_provider_selections_mode")
  @@index([selectedProviderProfileId], map: "idx_provider_selections_provider")
  @@index([selectedAgencyId], map: "idx_provider_selections_agency")
  @@map("provider_selections")
}

model MarketplaceOffer {
  id                    String           @id @default(uuid()) @db.Uuid
  deliveryRequestId     String           @map("delivery_request_id") @db.Uuid
  providerProfileId     String?          @map("provider_profile_id") @db.Uuid
  agencyId              String?          @map("agency_id") @db.Uuid
  offerAmount           Decimal          @map("offer_amount") @db.Decimal(12, 2)
  currency              String           @default("XAF") @db.VarChar(8)
  estimatedPickupTime   DateTime?        @map("estimated_pickup_time") @db.Timestamptz
  estimatedDeliveryTime DateTime?        @map("estimated_delivery_time") @db.Timestamptz
  message               String?
  offerStatus           OfferStatus      @default(submitted) @map("offer_status")
  submittedAt           DateTime         @default(now()) @map("submitted_at") @db.Timestamptz
  acceptedAt            DateTime?        @map("accepted_at") @db.Timestamptz
  rejectedAt            DateTime?        @map("rejected_at") @db.Timestamptz
  expiredAt             DateTime?        @map("expired_at") @db.Timestamptz
  createdAt             DateTime         @default(now()) @map("created_at") @db.Timestamptz
  updatedAt             DateTime         @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt             DateTime?        @map("deleted_at") @db.Timestamptz
  request               DeliveryRequest  @relation("RequestOffers", fields: [deliveryRequestId], references: [id])
