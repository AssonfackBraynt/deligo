  actorCustomerContact   CustomerContact? @relation(fields: [actorCustomerContactId], references: [id])

  @@index([actorUserId], map: "idx_audit_logs_actor_user")
  @@index([entityType, entityId], map: "idx_audit_logs_entity")
  @@index([action], map: "idx_audit_logs_action")
  @@index([createdAt], map: "idx_audit_logs_created_at")
  @@map("audit_logs")
}

model SystemSetting {
  id           String   @id @default(uuid()) @db.Uuid
  settingKey   String   @unique @map("setting_key") @db.VarChar(120)
  settingValue Json     @map("setting_value")
  description  String?
  isPublic     Boolean  @default(false) @map("is_public")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz
  updatedBy    String?  @map("updated_by") @db.Uuid

  @@map("system_settings")
}

// ── Provider Branches (company sub-locations) ──────────────────────────────────

model ProviderBranch {
  id                String          @id @default(uuid()) @db.Uuid
  providerProfileId String          @map("provider_profile_id") @db.Uuid
  quarterId         String          @map("quarter_id") @db.Uuid
  name              String          @db.VarChar(180)
  phoneNumber       String?         @map("phone_number") @db.VarChar(32)
  isHeadquarters    Boolean         @default(false) @map("is_headquarters")
  isActive          Boolean         @default(true) @map("is_active")
  createdAt         DateTime        @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime        @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt         DateTime?       @map("deleted_at") @db.Timestamptz
  providerProfile   ProviderProfile @relation(fields: [providerProfileId], references: [id])
  quarter           Quarter         @relation(fields: [quarterId], references: [id])

  @@index([providerProfileId], map: "idx_provider_branches_profile")
  @@index([quarterId], map: "idx_provider_branches_quarter")
  @@map("provider_branches")
}

// ── Rider Planned Routes ────────────────────────────────────────────────────────

model RiderRoute {
  id                   String          @id @default(uuid()) @db.Uuid
  providerProfileId    String          @map("provider_profile_id") @db.Uuid
  originQuarterId      String          @map("origin_quarter_id") @db.Uuid
  destinationQuarterId String          @map("destination_quarter_id") @db.Uuid
  departureTime        String?         @map("departure_time") @db.VarChar(8)
  isRecurring          Boolean         @default(false) @map("is_recurring")
  recurringDays        Json?           @map("recurring_days")
  isActive             Boolean         @default(true) @map("is_active")
  createdAt            DateTime        @default(now()) @map("created_at") @db.Timestamptz
  updatedAt            DateTime        @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt            DateTime?       @map("deleted_at") @db.Timestamptz
  providerProfile      ProviderProfile @relation(fields: [providerProfileId], references: [id])
  originQuarter        Quarter         @relation("RiderRouteOrigin", fields: [originQuarterId], references: [id])
  destinationQuarter   Quarter         @relation("RiderRouteDestination", fields: [destinationQuarterId], references: [id])

  @@index([providerProfileId], map: "idx_rider_routes_profile")
  @@index([originQuarterId], map: "idx_rider_routes_origin")
  @@index([destinationQuarterId], map: "idx_rider_routes_destination")
  @@index([isActive], map: "idx_rider_routes_active")
  @@map("rider_routes")
}
