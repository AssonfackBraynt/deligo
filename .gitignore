# ── Dependencies ──────────────────────────────────────────────────────────────
node_modules/
frontend/node_modules/

# ── Build outputs ─────────────────────────────────────────────────────────────
dist/
frontend/.next/
frontend/out/

# ── Environment variables — NEVER commit real credentials ─────────────────────
.env
.env.*
!.env.example
frontend/.env
frontend/.env.*
!frontend/.env.example

# ── TypeScript ────────────────────────────────────────────────────────────────
*.tsbuildinfo

# ── Logs ──────────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── Testing ───────────────────────────────────────────────────────────────────
coverage/

# ── Runtime uploads ───────────────────────────────────────────────────────────
uploads/

# ── Data files (may contain personal/provider data) ──────────────────────────
*.xlsx
*.xls
*.csv

# ── OS artifacts ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Editor/IDE ────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── Claude Code session data ──────────────────────────────────────────────────
.claude/
